{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Web3270": "Debug",
        "Web3270.Tn3270": "Information",
        "Web3270.Server": "Information"
      }
    }
  },
  "Tn3270": {
    "StreamCapture": {
      "Enabled": false,
      "Directory": "traces"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5001"
      }
    }
  }
}
